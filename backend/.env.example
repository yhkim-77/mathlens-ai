# MathLens AI Backend - Environment Variables Example
# Copy this file to .env and fill in your values

# ================================
# Application Settings
# ================================
DEBUG=false
APP_NAME=MathLens AI API
APP_VERSION=1.0.0

# ================================
# Database
# ================================
# For development (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./mathlens.db

# For production (PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://mathlens:password@localhost:5432/mathlens

# ================================
# Security (REQUIRED)
# ================================
# Generate a secure secret key with: openssl rand -hex 32
# WARNING: Never use a weak or default key in production!
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32

# ================================
# AI Services
# ================================
# OpenAI API Key (required for AI analysis features)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Anthropic API Key (optional backup)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# MathPix OCR (optional)
# MATHPIX_APP_ID=your-app-id
# MATHPIX_APP_KEY=your-app-key

# ================================
# Redis (Optional)
# ================================
# REDIS_URL=redis://localhost:6379/0

# ================================
# CORS Settings
# ================================
# Add your frontend URLs here (comma-separated in production)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ================================
# Image Upload Limits
# ================================
MAX_IMAGE_BYTES_BASE64=2800000
MAX_IMAGE_UPLOAD_BYTES=2097152
